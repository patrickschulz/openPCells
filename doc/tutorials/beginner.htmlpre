                <rect style = "fill:#ffff00; opacity:0.7; fill-opacity:0.7" x="2095" y="750" width="50" height="50" />
                <rect style = "fill:#ffff00; opacity:0.7; fill-opacity:0.7" x="2095" y="600" width="50" height="50" />
